{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Compilar e Rodar Java (CMD Externo)",
      "type": "shell",
      "command": "cmd",
      "args": [
        "/c",
        "javac -d \"${workspaceFolder}\\bin\" \"${file}\" && cd \"${workspaceFolder}\\bin\" && start cmd /c \"java ${fileBasenameNoExtension} & pause\""
      ],
      "group": {
        "kind": "build",
        "isDefault": true,
      },
      "detail": "Compila para o bin e abre o CMD externo para executar o código."
    }
  ]
}